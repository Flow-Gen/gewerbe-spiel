{
  "functions": {
    "api/webhook.js": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/konstanz",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/konstanz",
      "destination": "/konstanz/index.html"
    },
    {
      "source": "/loerrach",
      "destination": "/loerrach/index.html"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
